# Copy to `.env` for local development.

# Server-only Postgres connection string.
# Local default points at the Docker Compose Postgres service.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/pawboard

# Private operator sign-in code. Local default is `demo`.
OPERATOR_ACCESS_CODE=demo

# Reserved for production auth + Supabase wiring (not required locally).
# BETTER_AUTH_SECRET=
# BETTER_AUTH_URL=
# SUPABASE_URL=
# SUPABASE_SERVICE_ROLE_KEY=
